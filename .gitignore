# --- Dependencies ---
node_modules/
.venv/
__pycache__/
*.pyc

# --- Build / runtime artifacts ---
.logs/
.pids/
*.log
qaflow-tool/backend/qaflow.sqlite3
qaflow-tool/backend/sandbox_workspace/
qaflow-tool/backend/screenshots/
cypress-tests/cypress/screenshots/
cypress-tests/cypress/videos/
